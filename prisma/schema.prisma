generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id          String    @id @default(cuid())
  name        String
  ownerName   String
  phone       String
  address     String
  city        String
  state       String
  openingTime String
  closingTime String

  barbers     Barber[]
  services    Service[]
  customers   Customer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Barber {
  id          String   @id @default(cuid())
  name        String
  phone       String
  experience  Int
  status      String

  shopId      String
  shop        Shop @relation(fields: [shopId], references: [id])

  queues      Queue[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String
  price       Float
  duration    Int

  shopId      String
  shop        Shop @relation(fields: [shopId], references: [id])

  queues      Queue[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String?

  totalVisits Int      @default(0)
  totalSpent  Float    @default(0)

  shopId      String
  shop        Shop @relation(fields: [shopId], references: [id])

  queues      Queue[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Queue {
  id           String   @id @default(cuid())

  tokenNumber  Int
  status       String

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])

  barberId     String
  barber       Barber @relation(fields: [barberId], references: [id])

  serviceId    String
  service      Service @relation(fields: [serviceId], references: [id])

  createdAt    DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
}